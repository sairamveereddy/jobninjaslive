GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

JWT_SECRET=change_this_to_a_random_32_character_string
JWT_EXPIRE_HOURS=720

DODO_API_KEY=your_dodo_api_key
DODO_WEBHOOK_SECRET=your_dodo_webhook_secret
DODO_PRODUCT_ID=your_lifetime_product_id
DODO_PRICE_CENTS=1900

ADMIN_EMAIL=you@yourcompany.com
# DATABASE_URL is intentionally omitted so backend/database.py
# can place SQLite in a local non-OneDrive folder to avoid disk I/O errors.
APP_URL=http://localhost:8000
